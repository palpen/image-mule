{
  "name": "image-mule",
  "version": "1.0.2",
  "description": "Haul screenshots to your remote server via SFTP",
  "author": "palpen",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.image-mule.app",
    "productName": "Image Mule",
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "ssh2-sftp-client": "^9.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
